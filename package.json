{
  "name": "vue-rentmate",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:api": "tsx watch server/index.js",
    "start:api": "node server/index.js",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "run-s lint:*",
    "lint:types": "vue-tsc --noEmit",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/ components/ lib/ server/"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@google-cloud/storage": "^7.19.0",
    "@google-cloud/vision": "^5.3.5",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-vue-next": "^0.513.0",
    "maplibre-gl": "^5.24.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "reka-ui": "^2.9.5",
    "simple-icons": "^16.15.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@typescript-eslint/parser": "^8.47.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.57.0",
    "eslint-plugin-vue": "~10.8.0",
    "globals": "^17.4.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.57.0",
    "prettier": "3.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue-tsc": "^2.2.0"
  }
}
