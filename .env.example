# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# OCR API: Local Express OCR server for contract scanning.
OCR_API_PORT="8787"

# Google Cloud Vision will read this service account JSON locally via ADC.
# Example on Windows:
# GOOGLE_APPLICATION_CREDENTIALS="C:\\keys\\rentmate-vision.json"
GOOGLE_APPLICATION_CREDENTIALS="C:\\path\\to\\service-account.json"

# Optional: dev proxy target for Vite.
VITE_OCR_API_URL="http://localhost:8787"

# Google OAuth web-server flow. Never expose GOOGLE_CLIENT_SECRET to Vite/browser code.
GOOGLE_CLIENT_ID="YOUR_GOOGLE_WEB_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_WEB_CLIENT_SECRET"
# Alternative to GOOGLE_CLIENT_SECRET: load Google's downloaded OAuth JSON directly.
GOOGLE_CLIENT_SECRET_FILE="C:\\path\\to\\client_secret.json"
GOOGLE_REDIRECT_URI="http://localhost:8000/api/auth/google/callback"
FRONTEND_URL="http://localhost:5173"
VITE_API_BASE_URL="http://localhost:8000/api"

# MySQL and email verification. Keep these values on the backend only.
DATABASE_URL="mysql+pymysql://username:password@localhost:3306/115-RentMate"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USERNAME="your-account@gmail.com"
SMTP_APP_PASSWORD="YOUR_16_DIGIT_GOOGLE_APP_PASSWORD"
SMTP_FROM_EMAIL="your-account@gmail.com"
SMTP_FROM_NAME="RentMate"
VERIFICATION_CODE_SECRET="GENERATE_AT_LEAST_32_RANDOM_BYTES"
VERIFICATION_CODE_EXPIRES_SECONDS="120"
VERIFICATION_CODE_MAX_ATTEMPTS="3"
VERIFICATION_RESEND_COOLDOWN_SECONDS="60"
VERIFICATION_MAX_SENDS="5"
